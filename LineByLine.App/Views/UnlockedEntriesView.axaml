<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:LineByLine.App.ViewModels"
             x:DataType="vm:UnlockedEntriesViewModel"
             x:Class="LineByLine.App.Views.UnlockedEntriesView">

    <UserControl.KeyBindings>
        <KeyBinding Gesture="Escape" Command="{Binding BackCommand}"/>
    </UserControl.KeyBindings>

    <DockPanel>

        <StackPanel DockPanel.Dock="Top" Margin="64,40,64,0">
            <TextBlock Text="{Binding ContextHeader}"
                       FontSize="{DynamicResource FontSizeTitle}"
                       FontWeight="Bold"
                       Foreground="#c8c8c8"
                       Margin="0,0,0,4"/>
            <TextBlock Text="esc to return   page up / page down to scroll"
                       FontSize="{DynamicResource FontSizeHint}"
                       Foreground="#2a2a2a"/>
        </StackPanel>

        <Border DockPanel.Dock="Top" Height="1" Background="#1e1e1e" Margin="64,16,64,0"/>

        <TextBlock DockPanel.Dock="Top"
                   Text="{Binding StatusMessage}"
                   Foreground="#444444"
                   Margin="64,24,64,0"
                   IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

        <ScrollViewer x:Name="EntriesScrollViewer"
                      Margin="64,24,64,40"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Focusable="True">
            <ItemsControl ItemsSource="{Binding Entries}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:UnlockedEntryDisplay">
                        <StackPanel Margin="0,0,0,28">
                            <TextBlock Text="{Binding Timestamp}"
                                       FontSize="{DynamicResource FontSizeHint}"
                                       Foreground="#444444"
                                       Margin="0,0,0,6"/>
                            <TextBlock Text="{Binding Plaintext}"
                                       Foreground="#b0b0b0"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

    </DockPanel>
</UserControl>
