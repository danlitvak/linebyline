<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:LineByLine.App.ViewModels"
        x:DataType="vm:MainWindowViewModel"
        x:Class="LineByLine.App.Views.MainWindow"
        Title="Line by Line"
        Background="#0d0d0d"
        Width="720" Height="560"
        MinWidth="480" MinHeight="380"
        WindowStartupLocation="CenterScreen">

    <Window.KeyBindings>
        <KeyBinding Gesture="Ctrl+L" Command="{Binding LockCommand}"/>
        <KeyBinding Gesture="Ctrl+W" Command="{Binding EmergencyCloseCommand}"/>
    </Window.KeyBindings>

    <ContentControl Content="{Binding CurrentScreen}"/>
</Window>
