<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:LineByLine.App.ViewModels"
        x:DataType="vm:MainWindowViewModel"
        x:Class="LineByLine.App.Views.MainWindow"
        Title="Line by Line"
        Background="#0d0d0d"
        Width="720" Height="560"
        MinWidth="480" MinHeight="380"
        WindowStartupLocation="CenterScreen">

    <!-- Lock (Ctrl/Cmd+L) and emergency close (Ctrl/Cmd+W) are bound in
         code-behind so they use the platform command modifier:
         Ctrl on Windows/Linux, Cmd on macOS. -->

    <ContentControl Content="{Binding CurrentScreen}"/>
</Window>
